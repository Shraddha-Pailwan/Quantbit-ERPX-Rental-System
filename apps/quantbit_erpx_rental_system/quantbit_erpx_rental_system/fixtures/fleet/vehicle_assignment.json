{
  "doctype": "DocType",
  "name": "Vehicle Assignment",
  "module": "ERPX Rental",
  "naming_rule": "Expression",
  "autoname": "format:VA-{YYYY}-{#####}",
  "is_submittable": 1,
  "track_changes": 1,
  "description": "Internal Fleet: assigns a vehicle to an employee/driver for a defined period.",
  "fields": [
    {
      "fieldname": "vehicle",
      "fieldtype": "Link",
      "label": "Vehicle / Plate",
      "options": "Vehicle Master",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "driver",
      "fieldtype": "Link",
      "label": "Assigned Driver",
      "options": "Driver Master",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "department",
      "fieldtype": "Link",
      "label": "Department",
      "options": "Department"
    },
    {
      "fieldname": "col_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "assignment_from",
      "fieldtype": "Date",
      "label": "Assignment From",
      "reqd": 1
    },
    {
      "fieldname": "assignment_to",
      "fieldtype": "Date",
      "label": "Assignment To"
    },
    {
      "fieldname": "assignment_type",
      "fieldtype": "Select",
      "label": "Assignment Type",
      "options": "Permanent Assignment\nTemporary Assignment\nSingle Trip",
      "default": "Permanent Assignment"
    },
    {
      "fieldname": "col_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "km_at_assignment",
      "fieldtype": "Float",
      "label": "Odometer at Assignment Start (KM)"
    },
    {
      "fieldname": "assignment_status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Active\nCompleted\nCancelled",
      "default": "Active",
      "in_list_view": 1
    },
    {
      "fieldname": "purpose",
      "fieldtype": "Small Text",
      "label": "Assignment Purpose / Notes"
    }
  ],
  "permissions": [
    {"role": "Fleet Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1},
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1, "delete": 1}
  ]
}
