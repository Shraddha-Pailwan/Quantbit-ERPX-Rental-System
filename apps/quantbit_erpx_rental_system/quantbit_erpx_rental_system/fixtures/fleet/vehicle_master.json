      "fieldname": "col_break_12",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "loan_start_date",
      "fieldtype": "Date",
      "label": "Loan Start Date",
      "depends_on": "eval:doc.is_financed!='No'"
    },
    {
      "fieldname": "loan_end_date",
      "fieldtype": "Date",
      "label": "Loan End / Payoff Date",
      "depends_on": "eval:doc.is_financed!='No'"
    },
    {
      "fieldname": "total_loan_amount",
      "fieldtype": "Currency",
      "label": "Total Loan Amount (OMR)",
      "options": "currency",
      "depends_on": "eval:doc.is_financed!='No'"
