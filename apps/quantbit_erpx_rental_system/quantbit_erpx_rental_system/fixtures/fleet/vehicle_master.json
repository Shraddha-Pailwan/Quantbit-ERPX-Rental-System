      "options": "Asset",
      "read_only": 1,
      "description": "Auto-created when vehicle is saved"
    },
    {
      "fieldname": "cost_centre",
      "fieldtype": "Link",
      "label": "Cost Centre",
      "options": "Cost Centre",
      "read_only": 1,
      "description": "Auto-created on save — format: CC-#### Plate Number"
