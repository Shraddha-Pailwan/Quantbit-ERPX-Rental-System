    {
      "fieldname": "engine_number",
      "fieldtype": "Data",
      "label": "Engine Number",
      "reqd": 1
    },
    {
      "fieldname": "engine_capacity_cc",
      "fieldtype": "Int",
      "label": "Engine Capacity (cc)"
    },
    {
      "fieldname": "col_break_6",
