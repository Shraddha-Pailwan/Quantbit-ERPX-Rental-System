      "fieldtype": "Section Break",
      "label": "Equipment & Features",
      "collapsible": 1
    },
    {
      "fieldname": "air_conditioning",
      "fieldtype": "Check",
      "label": "Air Conditioning",
      "default": "1"
    },
    {
      "fieldname": "sunroof",
      "fieldtype": "Check",
      "label": "Sunroof"
    },
    {
      "fieldname": "cruise_control",
      "fieldtype": "Check",
      "label": "Cruise Control"
    },
    {
      "fieldname": "parking_sensors",
      "fieldtype": "Check",
      "label": "Parking Sensors"
    },
