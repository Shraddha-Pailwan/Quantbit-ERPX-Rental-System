    },
    {
      "fieldname": "fuel_type",
      "fieldtype": "Select",
      "label": "Fuel Type / نوع الوقود",
      "options": "Petrol\nDiesel\nHybrid\nElectric\nCNG",
      "reqd": 1
    },
    {
      "fieldname": "transmission",
      "fieldtype": "Select",
      "label": "Transmission / ناقل الحركة",
      "options": "Automatic\nManual\nCVT\nSemi-Automatic"
    },
    {
      "fieldname": "drive_type",
      "fieldtype": "Select",
      "label": "Drive Type",
      "options": "FWD\nRWD\n4WD\nAWD"
    },
    {
      "fieldname": "col_break_7",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "fuel_tank_capacity_litres",
      "fieldtype": "Float",
      "label": "Fuel Tank Capacity (Litres)"
    },
    {
      "fieldname": "current_odometer_km",
      "fieldtype": "Float",
      "label": "Current Odometer (KM)",
