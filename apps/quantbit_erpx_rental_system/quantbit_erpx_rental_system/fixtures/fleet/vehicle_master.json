      "label": "Bluetooth Audio",
      "default": "1"
    },
    {
      "fieldname": "navigation_gps",
      "fieldtype": "Check",
      "label": "Navigation / GPS"
    },
    {
      "fieldname": "leather_seats",
      "fieldtype": "Check",
      "label": "Leather Seats"
