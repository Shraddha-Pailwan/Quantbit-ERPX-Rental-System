      "fieldname": "section_identity",
      "fieldtype": "Section Break",
      "label": "Vehicle Identity"
    },
    {
      "fieldname": "plate_number",
      "fieldtype": "Data",
      "label": "Plate Number / رقم اللوحة",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "description": "GCC format — include country suffix e.g. 2847 OM"
    },
    {
      "fieldname": "col_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "vehicle_status",
      "fieldtype": "Select",
      "label": "Vehicle Status",
      "options": "Available\nOn Rent\nIn Workshop\nReserved\nRetired\nBlocked",
      "default": "Available",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "col_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "vehicle_use",
      "fieldtype": "Select",
      "label": "Vehicle Use Tag",
      "options": "Rental\nInternal Fleet",
      "reqd": 1,
      "in_list_view": 1,
      "description": "Strict separation — cannot be changed after first contract is created"
    },
    {
      "fieldname": "section_basic",
      "fieldtype": "Section Break",
      "label": "Make & Model"
    },
    {
      "fieldname": "make",
      "fieldtype": "Data",
      "label": "Make / Brand",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "model",
      "fieldtype": "Data",
      "label": "Model",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "year_of_manufacture",
      "fieldtype": "Int",
      "label": "Year of Manufacture",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "col_break_3",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "vehicle_category",
      "fieldtype": "Select",
      "label": "Vehicle Category",
      "options": "Economy\nSedan\nSUV\nLuxury\nVan / Minibus\nPickup Truck\n4x4 Off-Road\nMotorcycle",
      "reqd": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "body_type",
      "fieldtype": "Select",
      "label": "Body Type",
      "options": "Saloon\nSUV / Crossover\nHatchback\nCoupe\nPickup\nVan\nMinivan"
    },
    {
      "fieldname": "colour",
      "fieldtype": "Data",
      "label": "Colour / لون"
    },
    {
      "fieldname": "col_break_4",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "number_of_seats",
      "fieldtype": "Int",
      "label": "Number of Seats / مقاعد",
      "default": "5"
    },
    {
      "fieldname": "number_of_doors",
      "fieldtype": "Int",
      "label": "Number of Doors",
      "default": "4"
    },
    {
      "fieldname": "section_ownership",
      "fieldtype": "Section Break",
      "label": "Ownership"
