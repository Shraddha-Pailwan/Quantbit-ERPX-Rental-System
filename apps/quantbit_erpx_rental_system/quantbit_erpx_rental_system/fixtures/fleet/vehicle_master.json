{
  "doctype": "DocType",
  "name": "Vehicle Master",
  "module": "ERPX Rental",
  "naming_rule": "Expression",
  "autoname": "field:plate_number",
  "is_submittable": 0,
  "track_changes": 1,
  "description": "Core vehicle record for both Rent-a-Car and Internal Fleet modes. One Cost Centre auto-created per vehicle for P&L tracking.",
