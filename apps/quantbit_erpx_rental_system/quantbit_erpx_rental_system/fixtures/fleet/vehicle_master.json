      "label": "Push Start"
    },
    {
      "fieldname": "keyless_entry",
      "fieldtype": "Check",
      "label": "Keyless Entry"
    },
    {
      "fieldname": "roof_rails",
      "fieldtype": "Check",
      "label": "Roof Rails"
    },
    {
      "fieldname": "tow_bar",
