{
  "doctype": "DocType",
  "name": "Driver Master",
  "module": "ERPX Rental",
  "naming_rule": "Expression",
  "autoname": "format:DRV-{#####}",
  "track_changes": 1,
  "description": "Employee driver record for Internal Fleet mode — linked to HR Employee, tracks licence, assignments, and fuel usage.",
  "fields": [
    {
      "fieldname": "employee",
      "fieldtype": "Link",
      "label": "HR Employee",
      "options": "Employee",
      "in_list_view": 1,
      "description": "Link to Frappe HR Employee record"
    },
    {
      "fieldname": "driver_name",
      "fieldtype": "Data",
      "label": "Driver Full Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "employee_id",
      "fieldtype": "Data",
      "label": "Employee ID"
    },
    {
      "fieldname": "col_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "department",
      "fieldtype": "Link",
      "label": "Department",
      "options": "Department"
    },
    {
      "fieldname": "mobile_number",
      "fieldtype": "Data",
      "label": "Mobile Number"
    },
    {
      "fieldname": "driver_status",
      "fieldtype": "Select",
      "label": "Driver Status",
      "options": "Available\nOn Assignment\nOn Leave\nInactive",
      "default": "Available",
      "in_list_view": 1
    },
    {
      "fieldname": "section_licence",
      "fieldtype": "Section Break",
      "label": "Driving Licence"
    },
    {
      "fieldname": "licence_number",
      "fieldtype": "Data",
      "label": "Driving Licence Number",
      "reqd": 1
    },
    {
      "fieldname": "licence_category",
      "fieldtype": "Select",
      "label": "Licence Category",
      "options": "Light Vehicle - Category A\nHeavy Vehicle - Category B\nMotorcycle - Category D"
    },
    {
      "fieldname": "licence_expiry_date",
      "fieldtype": "Date",
      "label": "Licence Expiry Date",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "col_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "iqama_number",
      "fieldtype": "Data",
      "label": "Iqama / National ID No."
    },
    {
      "fieldname": "iqama_expiry",
      "fieldtype": "Date",
      "label": "Iqama / ID Expiry"
    },
    {
      "fieldname": "nationality",
      "fieldtype": "Data",
      "label": "Nationality"
    },
    {
      "fieldname": "section_stats",
      "fieldtype": "Section Break",
      "label": "Statistics (read-only)",
      "collapsible": 1
    },
    {
      "fieldname": "total_trips",
      "fieldtype": "Int",
      "label": "Total Trips Completed",
      "read_only": 1,
      "default": "0"
    },
    {
      "fieldname": "total_km_driven",
      "fieldtype": "Float",
      "label": "Total KM Driven",
      "read_only": 1,
      "default": "0"
    },
    {
      "fieldname": "current_vehicle_assignment",
      "fieldtype": "Link",
      "label": "Current Vehicle Assignment",
      "options": "Vehicle Assignment",
      "read_only": 1
    }
  ],
  "permissions": [
    {"role": "Fleet Manager", "read": 1, "write": 1, "create": 1},
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1}
  ]
}
