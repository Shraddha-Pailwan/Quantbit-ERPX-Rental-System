{
  "doctype": "DocType",
  "name": "Fuel Entry",
  "module": "ERPX Rental",
  "naming_rule": "Expression",
  "autoname": "format:FE-{YYYY}-{#####}",
  "is_submittable": 1,
  "track_changes": 1,
  "description": "Fuel refill record — tracks litres, cost, station, and linked to trip/vehicle. Used for fuel cost analysis in Internal Fleet.",
  "fields": [
    {
      "fieldname": "vehicle",
      "fieldtype": "Link",
      "label": "Vehicle / Plate",
      "options": "Vehicle Master",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "driver",
      "fieldtype": "Link",
      "label": "Driver",
      "options": "Driver Master",
      "in_list_view": 1
    },
    {
      "fieldname": "fuel_date",
      "fieldtype": "Date",
      "label": "Refuel Date",
      "reqd": 1,
      "in_list_view": 1,
      "default": "Today"
    },
    {
      "fieldname": "col_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "fuel_type",
      "fieldtype": "Select",
      "label": "Fuel Type",
      "options": "Petrol\nDiesel\nPremium Petrol",
      "reqd": 1
    },
    {
      "fieldname": "litres_filled",
      "fieldtype": "Float",
      "label": "Litres Filled",
      "reqd": 1
    },
    {
      "fieldname": "cost_per_litre",
      "fieldtype": "Currency",
      "label": "Cost per Litre (OMR)",
      "options": "currency"
    },
    {
      "fieldname": "total_cost",
      "fieldtype": "Currency",
      "label": "Total Cost (OMR)",
      "options": "currency",
      "read_only": 1
    },
    {
      "fieldname": "col_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "odometer_at_refuel",
      "fieldtype": "Float",
      "label": "Odometer at Refuel (KM)"
    },
    {
      "fieldname": "fuel_station",
      "fieldtype": "Data",
      "label": "Fuel Station / Location"
    },
    {
      "fieldname": "receipt_number",
      "fieldtype": "Data",
      "label": "Receipt / Invoice No."
    },
    {
      "fieldname": "linked_trip_log",
      "fieldtype": "Link",
      "label": "Linked Trip Log",
      "options": "Trip Log"
    },
    {
      "fieldname": "payment_method",
      "fieldtype": "Select",
      "label": "Payment Method",
      "options": "Fuel Card\nCash\nCompany Card\nPetty Cash"
    },
    {
      "fieldname": "cost_centre",
      "fieldtype": "Link",
      "label": "Cost Centre",
      "options": "Cost Centre",
      "fetch_from": "vehicle.cost_centre"
    },
    {
      "fieldname": "fuel_expense_account",
      "fieldtype": "Link",
      "label": "GL Fuel Expense Account",
      "options": "Account"
    }
  ],
  "permissions": [
    {"role": "Fleet Manager", "read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1, "delete": 1}
  ]
}
