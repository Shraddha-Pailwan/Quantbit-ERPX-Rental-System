{
  "doctype": "DocType",
  "name": "Vehicle Document",
  "module": "ERPX Rental",
  "naming_rule": "Expression",
  "autoname": "format:VDOC-{YYYY}-{#####}",
  "is_submittable": 0,
  "track_changes": 1,
  "description": "Tracks all compliance documents per vehicle — Mulkiya, insurance, fitness cert, permits — with expiry alerts.",
  "fields": [
    {
      "fieldname": "vehicle",
      "fieldtype": "Link",
      "label": "Vehicle / Plate",
      "options": "Vehicle Master",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "document_type",
      "fieldtype": "Select",
      "label": "Document Type",
      "options": "Mulkiya / Registration\nInsurance Policy\nVehicle Fitness Certificate\nCommercial Permit\nTourism / Rental Permit\nROP Clearance Certificate\nOther",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "document_number",
      "fieldtype": "Data",
      "label": "Document Number",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "col_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "issuing_authority",
      "fieldtype": "Data",
      "label": "Issuing Authority",
      "reqd": 1
    },
    {
      "fieldname": "issue_date",
      "fieldtype": "Date",
      "label": "Issue Date"
    },
    {
      "fieldname": "expiry_date",
      "fieldtype": "Date",
      "label": "Expiry Date",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "col_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "renewal_alert_days",
      "fieldtype": "Int",
      "label": "Alert Days Before Expiry",
      "default": "30",
      "description": "WhatsApp alert sent this many days before expiry date"
    },
    {
      "fieldname": "document_status",
      "fieldtype": "Select",
      "label": "Document Status",
      "options": "Valid\nExpiring Soon\nExpired\nRenewal In Progress\nRenewed - Awaiting Document",
      "default": "Valid",
      "in_list_view": 1
    },
    {
      "fieldname": "section_renewal",
      "fieldtype": "Section Break",
      "label": "Renewal Details",
      "collapsible": 1
    },
    {
      "fieldname": "renewal_reference",
      "fieldtype": "Data",
      "label": "Renewal Reference / Receipt No."
    },
    {
      "fieldname": "renewal_cost",
      "fieldtype": "Currency",
      "label": "Renewal Cost (OMR)",
      "options": "currency"
    },
    {
      "fieldname": "renewal_date",
      "fieldtype": "Date",
      "label": "Date Renewed"
    },
    {
      "fieldname": "col_break_3",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "renewed_by",
      "fieldtype": "Link",
      "label": "Renewed By",
      "options": "User"
    },
    {
      "fieldname": "document_scan",
      "fieldtype": "Attach",
      "label": "Document Scan / Upload"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes"
    }
  ],
  "permissions": [
    {
      "role": "Fleet Manager",
      "read": 1, "write": 1, "create": 1, "delete": 0
    },
    {
      "role": "System Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1
    }
  ]
}
